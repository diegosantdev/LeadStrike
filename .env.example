# Google Places API
GOOGLE_PLACES_API_KEY=your_api_key_here

# Search Configuration
MIN_REVIEW_COUNT=20
MIN_RATING=4.0
SEARCH_RADIUS=5000
SCORE_THRESHOLD=80

# Lead Scoring Weights
SCORE_NO_WEBSITE=40
SCORE_BAD_WEBSITE=25
SCORE_HIGH_REVIEWS=30
SCORE_GOOD_RATING=25
SCORE_HAS_CONTACT=20
SCORE_OPERATIONAL=10
